# =========================
# llama.cpp / Docker
# =========================

LLAMA_PORT=8080

# =========================
# Model
# HF_REPO: HuggingFace repository (e.g. unsloth/Qwen3-30B-A3B-GGUF)
# MODEL_DIR: local folder name under models/
# MODEL_FILENAME: exact .gguf filename from the HuggingFace repo page
# =========================

HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
MODEL_FILENAME=Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
MODEL_DIR=qwen3.6-35b-a3b-q4km

# Perplexity comparison (WikiText-2, 50 chunks, ctx=512, RTX 4070):
#
# | Quantization | PPL    | Δ vs Q8_0 | Speed    | Size    | N_CPU_MOE |
# |--------------|--------|-----------|----------|---------|-----------|
# | IQ2_M        | 6.6773 | +7.4%     | 2.14s/it | 11.5 GB | 35        |
# | Q4_K_M  ★   | 6.2402 | +0.4%     | 2.91s/it | 22.1 GB | 28        |
# | Q8_0         | 6.2181 | baseline  | 4.63s/it | 36.9 GB | 33        |
#
# Q4_K_M (★ active) — best balance: near-Q8 quality, 37% faster, 15 GB less RAM.

# To switch model, change the three lines above and set N_CPU_MOE accordingly:
# Q8_0   → N_CPU_MOE=33 | MODEL_FILENAME=Qwen3.6-35B-A3B-Q8_0.gguf        | MODEL_DIR=qwen3.6-35b-a3b-q8
# IQ2_M  → N_CPU_MOE=35 | MODEL_FILENAME=Qwen3.6-35B-A3B-UD-IQ2_M.gguf    | MODEL_DIR=qwen3.6-35b-a3b

# HF_REPO=unsloth/gemma-4-31B-it-GGUF
# MODEL_FILENAME=gemma-4-31B-it-UD-IQ2_M.gguf
# MODEL_DIR=gemma-4-31B-it-UD-IQ2_M

# HF_REPO=unsloth/gemma-4-26B-A4B-it-GGUF
# MODEL_FILENAME=gemma-4-26B-A4B-it-UD-Q2_K_XL.gguf
# MODEL_DIR=gemma-4-26B-A4B-it-UD-Q2_K_XL

# HF_REPO=Jackrong/Qwen3.5-9B-GLM5.1-Distill-v1-GGUF
# MODEL_FILENAME=Qwen3.5-9B-GLM5.1-Distill-v1-Q8_0.gguf
# MODEL_DIR=qwen3.5-9b-glm5.1-distill

# =========================
# Model Config
# =========================
N_GPU_LAYERS=-1
CTX_SIZE=262144
MAX_TOKENS=262144
REASONING=off

# false = KV-cache in RAM
# true  = KV-cache on GPU
KV_OFFLOAD=true
# =========================
# MoE CPU Offload
# Offloads N expert layers to CPU — keeps attention on GPU.
# Set to 0 to disable. Tune to find the GPU VRAM sweet spot.
# =========================
N_CPU_MOE=28

# =========================
# Memory
# NO_MMAP: load model fully into RAM (avoids page faults, faster inference)
# MLOCK: pin model in RAM to prevent OS swap (requires enough free RAM)
# =========================
NO_MMAP=true
MLOCK=true

# =========================
# KV Cache
# turbo4/turbo3 require the TheTom/llama-cpp-turboquant fork (WHT + PolarQuant).
# Fallback for standard llama.cpp: q8_0 (best quality) or q4_0 (less VRAM).
# =========================
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo3

# =========================
# Active sampling preset
# =========================
# Thinking / precise coding:
TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20
MIN_P=0.0
PRESENCE_PENALTY=0.0
REPEAT_PENALTY=1.0

# =========================
# Recommended presets — gemma-4-26B-A4B-it (MoE) / gemma-4-31B-it (dense)
# Same official parameters for both Gemma 4 models:
# =========================
# General (official recommendation):
# TEMPERATURE=1.0
# TOP_P=0.95
# TOP_K=64
# MIN_P=0.0
# PRESENCE_PENALTY=0.0
# REPEAT_PENALTY=1.0

# =========================
# Recommended presets — qwen3.5-9b-glm5.1-distill / qwen3.6-35b-a3b
# (Qwen3 family — same recommended parameters)
# =========================
# Thinking / general:
# TEMPERATURE=1.0
# TOP_P=0.95
# TOP_K=20
# MIN_P=0.0
# PRESENCE_PENALTY=1.5
# REPEAT_PENALTY=1.0

# Thinking / precise coding:
# TEMPERATURE=0.6
# TOP_P=0.95
# TOP_K=20
# MIN_P=0.0
# PRESENCE_PENALTY=0.0
# REPEAT_PENALTY=1.0

# Instruct / non-thinking / general:
