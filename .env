# =========================
# llama.cpp / Docker
# =========================

LLAMA_PORT=8080

# =========================
# Model
# HF_REPO: HuggingFace repository (e.g. unsloth/Qwen3-30B-A3B-GGUF)
# MODEL_DIR: local folder name under models/
# MODEL_FILENAME: exact .gguf filename from the HuggingFace repo page
# =========================

HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
MODEL_DIR=qwen3.6-35b-a3b
MODEL_FILENAME=Qwen3.6-35B-A3B-UD-IQ2_M.gguf

# Previous config:
# N_GPU_LAYERS=30
# CTX_SIZE=32768
# KV_OFFLOAD=false

# Current active config: more aggressive for RTX 4070
N_GPU_LAYERS=30
CTX_SIZE=32768

# false = KV-cache in RAM
# true  = KV-cache on GPU
KV_OFFLOAD=false

REASONING=on

# =========================
# KV Cache
# =========================

CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# =========================
# Active sampling preset
# Dev / precise coding / non-thinking
# =========================

TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20
MIN_P=0.0
PRESENCE_PENALTY=0.0
REPEAT_PENALTY=1.0

# Thinking models generate long reasoning chains — 32768 recommended.
MAX_TOKENS=32768

# =========================
# Recommended presets
# =========================

# Thinking / general:
# TEMPERATURE=1.0
# TOP_P=0.95
# TOP_K=20
# MIN_P=0.0
# PRESENCE_PENALTY=1.5
# REPEAT_PENALTY=1.0

# Thinking / precise coding:
# TEMPERATURE=0.6
# TOP_P=0.95
# TOP_K=20
# MIN_P=0.0
# PRESENCE_PENALTY=0.0
# REPEAT_PENALTY=1.0

# Instruct / non-thinking / general:
# TEMPERATURE=0.7
# TOP_P=0.8
# TOP_K=20
# MIN_P=0.0
# PRESENCE_PENALTY=1.5
# REPEAT_PENALTY=1.0

# Instruct / non-thinking / reasoning:
# TEMPERATURE=1.0
# TOP_P=1.0
# TOP_K=40
# MIN_P=0.0
# PRESENCE_PENALTY=2.0
# REPEAT_PENALTY=1.0

# Short output:
# MAX_TOKENS=8192

# Extreme benchmark:
# MAX_TOKENS=81920
